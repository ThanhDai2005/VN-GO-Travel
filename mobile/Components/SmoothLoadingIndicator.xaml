<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VNGOTravel.Components.SmoothLoadingIndicator"
             x:Name="LoadingIndicator">

    <!-- Semi-transparent overlay with loading spinner -->
    <Grid BackgroundColor="#80000000"
          IsVisible="{Binding IsVisible, Source={x:Reference LoadingIndicator}}">

        <VerticalStackLayout HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="16">

            <!-- Modern loading spinner -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="32"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">
                    <!-- Activity Indicator -->
                    <ActivityIndicator IsRunning="True"
                                     Color="#2563EB"
                                     WidthRequest="48"
                                     HeightRequest="48"
                                     HorizontalOptions="Center"/>

                    <!-- Loading Message -->
                    <Label Text="{Binding Message, Source={x:Reference LoadingIndicator}}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1F2937"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentView>
