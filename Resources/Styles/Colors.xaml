<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand identity -->
    <Color x:Key="BrandPrimary">#10B981</Color>
    <Color x:Key="BrandPrimaryDark">#059669</Color>
    <Color x:Key="BrandAccent">#E7D050</Color>
    <Color x:Key="BrandDark">#5C362B</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceBackground">#FBF9F9</Color>
    <Color x:Key="SurfaceCard">#FFFFFF</Color>
    <Color x:Key="SurfaceSoft">#F5F0EF</Color>
    <Color x:Key="SurfaceDark">#5C362B</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#4A3B36</Color>
    <Color x:Key="TextSecondary">#877B77</Color>
    <Color x:Key="TextOnDark">#FFFFFF</Color>

    <!-- Border / shadow -->
    <Color x:Key="BorderLight">#5C362B</Color> <!-- Using BrandDark for borders as per rules -->
    <Color x:Key="ShadowColor">#15000000</Color>
</ResourceDictionary>