<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:ProfileViewModel"
    Title="Tài khoản"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,120" Spacing="18">

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Thông tin đăng nhập"
                           Style="{StaticResource SectionTitle}" />

                    <Label Text="{Binding DisplayEmail}"
                           FontSize="16"
                           TextColor="{StaticResource TextPrimary}" />

                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Vai trò:"
                               FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding RoleDisplay}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandPrimaryDark}" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Button Text="Đăng nhập"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoginCommand}"
                    IsVisible="{Binding IsNotLoggedIn}" />

            <Button Text="Dang xuat"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding LogoutCommand}"
                    IsVisible="{Binding IsLoggedIn}" />

            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding ShowOwnerSection}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Chu dia diem (OWNER)"
                           Style="{StaticResource SectionTitle}" />
                    <Label Text="Mo tab 'Gui POI' ben duoi, dien form va gui — diem se o trang thai cho Admin duyet."
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding ShowAdminSection}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Quản trị (ADMIN)"
                           Style="{StaticResource SectionTitle}" />
                    <Label Text="Bảng điều khiển: mở tab 'Quản trị' bên dưới (Web/API sẵn sàng)."
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
