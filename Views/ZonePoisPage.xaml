<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.ZonePoisPage"
             BackgroundColor="White"
             Title="Zone POIs">
    <Grid BackgroundColor="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
               BackgroundColor="#F8BBD0"
               Padding="20"
               Margin="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0"/>
            </Border.StrokeShape>
            <StackLayout>
                <Label x:Name="ZoneNameLabel"
                       Text="Zone Name"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#880E4F"
                       HorizontalOptions="Center"/>
                <Label x:Name="ZoneDescriptionLabel"
                       Text=""
                       FontSize="14"
                       TextColor="#AD1457"
                       HorizontalOptions="Center"
                       Margin="0,5,0,0"/>
                <Label x:Name="PoiCountLabel"
                       Text="0 locations"
                       FontSize="12"
                       TextColor="#AD1457"
                       HorizontalOptions="Center"
                       Margin="0,5,0,0"/>
            </StackLayout>
        </Border>

        <Grid Grid.Row="1">
            <CollectionView x:Name="PoisCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnPoiSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15"
                               Margin="10,5"
                               BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
                            </Border.Shadow>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label Text="{Binding Summary}"
                                           FontSize="14"
                                           TextColor="#666666"
                                           Margin="0,5,0,0"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"/>
                                    <Label Text="{Binding Code}"
                                           FontSize="12"
                                           TextColor="#999999"
                                           Margin="0,5,0,0"/>
                                </StackLayout>

                                <Image Grid.Column="1"
                                       Source="arrow_right.png"
                                       WidthRequest="24"
                                       HeightRequest="24"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="EmptyStateLabel"
                   Text="No POIs available in this zone"
                   FontSize="14"
                   TextColor="#666666"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   IsVisible="False"/>

            <Label x:Name="ErrorLabel"
                   Text="Unable to load zone"
                   FontSize="14"
                   TextColor="#D32F2F"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="12"
                   IsVisible="False"/>

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#E91E63"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
        </Grid>

        <Border x:Name="AccessFrame"
               Grid.Row="2"
               BackgroundColor="#FCE4EC"
               Padding="20"
               Margin="0"
               IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0"/>
            </Border.StrokeShape>
            <StackLayout>
                <Label x:Name="AccessMessageLabel"
                       Text="Purchase this zone to unlock all locations"
                       FontSize="14"
                       TextColor="#C2185B"
                       HorizontalOptions="Center"/>
                <Button x:Name="PurchaseButton"
                        Text="Purchase Zone"
                        BackgroundColor="#E91E63"
                        TextColor="White"
                        CornerRadius="8"
                        Margin="0,10,0,0"
                        Clicked="OnPurchaseClicked"/>
            </StackLayout>
        </Border>
    </Grid>
</ContentPage>
