<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.AudioPlayerComponent">
    <Border Padding="12" BackgroundColor="#F5F5F5" StrokeThickness="0">
        <VerticalStackLayout Spacing="10">
            <Label Text="Offline Audio Player"
                   FontAttributes="Bold"
                   FontSize="15" />

            <Label Text="Đang buffer..."
                   IsVisible="{Binding IsBuffering}" />

            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="{Binding AudioPositionText}" VerticalOptions="Center" />
                <Slider Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        Value="{Binding AudioSeekValue, Mode=TwoWay}" />
                <Label Grid.Column="2"
                       Text="{Binding AudioDurationText}"
                       VerticalOptions="Center" />
            </Grid>

            <HorizontalStackLayout Spacing="8">
                <Button Text="▶ Play"
                        Command="{Binding PlayPurchasedAudioCommand}" />
                <Button Text="⏸ Pause"
                        Command="{Binding PausePurchasedAudioCommand}" />
                <Button Text="↺ Replay"
                        Command="{Binding ReplayPurchasedAudioCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
