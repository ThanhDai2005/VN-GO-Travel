<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    x:Class="MauiApp1.Views.QrScannerPage"
    Title="Quét mã"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Camera first: primary focus -->
            <Frame
                Padding="0"
                CornerRadius="12"
                BackgroundColor="#0D0D0D"
                BorderColor="#2A2A2A"
                HasShadow="True">
                <Grid x:Name="CameraContainer" HeightRequest="400" BackgroundColor="#000">

                    <zxing:CameraBarcodeReaderView
                        x:Name="CameraView"
                        IsDetecting="False"
                        BarcodesDetected="OnBarcodesDetected" />

                    <!-- Top status strip (readable on dark preview) -->
                    <Border
                        VerticalOptions="Start"
                        BackgroundColor="#CC000000"
                        StrokeThickness="0"
                        Padding="12,10">
                        <VerticalStackLayout Spacing="8">
                            <ActivityIndicator
                                IsRunning="{Binding IsProcessingScan}"
                                IsVisible="{Binding IsProcessingScan}"
                                Color="White"
                                HeightRequest="28" />
                            <Label
                                Text="{Binding UxStatusText}"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="White"
                                LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Scan target: corner brackets + subtle scan line -->
                    <Grid
                        InputTransparent="True"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        WidthRequest="260"
                        HeightRequest="260">
                        <Border
                            Stroke="#B3FFFFFF"
                            StrokeThickness="2"
                            BackgroundColor="Transparent"
                            Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Grid x:Name="ScanFrameGrid">
                                <BoxView
                                    x:Name="ScanLine"
                                    HeightRequest="2"
                                    Color="#66FF4081"
                                    VerticalOptions="Start"
                                    HorizontalOptions="Fill"
                                    Margin="8,24,8,0" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Label
                        InputTransparent="True"
                        Text="Căn mã trong khung"
                        FontSize="12"
                        TextColor="#CCFFFFFF"
                        VerticalOptions="End"
                        HorizontalOptions="Center"
                        Margin="0,0,0,12" />
                </Grid>
            </Frame>

            <!-- Error / detail -->
            <Label
                Text="{Binding UxDetailError}"
                FontSize="14"
                TextColor="#D32F2F"
                LineBreakMode="WordWrap"
                IsVisible="{Binding HasDetailError}" />

            <!-- Manual fallback -->
            <Label Style="{StaticResource SectionTitle}" Text="Nhập mã thủ công" FontSize="18" />
            <Label
                Style="{StaticResource BodyText}"
                Text="Định dạng: poi:CODE hoặc URL https://…/poi/CODE"
                FontSize="13" />
            <Editor
                Text="{Binding InputText}"
                HeightRequest="100"
                Placeholder="Ví dụ: poi:HO_GUOM"
                IsEnabled="{Binding IsScannerAcceptingInput}" />

            <HorizontalStackLayout Spacing="10">
                <Button
                    Style="{StaticResource PrimaryButton}"
                    Text="Dùng mã đã nhập"
                    Command="{Binding ScanCommand}" />
                <Button
                    Style="{StaticResource SecondaryButton}"
                    Text="Đóng"
                    Command="{Binding CancelCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
