<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.PurchaseHistoryPage"
             Title="Lịch sử mua hàng"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">
    <Grid Padding="20" RowDefinitions="Auto,*">
        
        <VerticalStackLayout Spacing="4" Margin="0,0,0,20">
            <Label Text="Lịch sử giao dịch"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#2C3E50, Dark=#FFFFFF}" />
            <Label Text="Danh sách các khu vực bạn đã mở khóa"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#7F8C8D, Dark=#B0B0B0}" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15" Padding="40">
                    <Label Text="Empty History" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#BDC3C7, Dark=#4A4A4A}"/>
                    <Label Text="Bạn chưa mua khu vực nào. Hãy khám phá các địa danh trên bản đồ!" 
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#95A5A6, Dark=#7F8C8D}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0" 
                            Margin="0,0,0,16" 
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}" />
                        </Border.Shadow>
                        
                        <Grid ColumnDefinitions="8, *, Auto" Padding="16">
                            <!-- Status Indicator Strip -->
                            <BoxView Grid.Column="0" 
                                     BackgroundColor="#16A085" 
                                     WidthRequest="4" 
                                     Margin="0,4"
                                     CornerRadius="2" />

                            <VerticalStackLayout Grid.Column="1" Spacing="6" Margin="12,0,0,0">
                                <Label Text="{Binding ZoneName}" 
                                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=#ECF0F1}"
                                       FontAttributes="Bold" 
                                       FontSize="18" />
                                
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="󰄉" FontFamily="MaterialIcons" TextColor="#7F8C8D" VerticalOptions="Center"/>
                                    <Label Text="{Binding PurchasedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}" 
                                           TextColor="{AppThemeBinding Light=#7F8C8D, Dark=#95A5A6}"
                                           FontSize="13" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="󰋙" FontFamily="MaterialIcons" TextColor="#7F8C8D" VerticalOptions="Center"/>
                                    <Label Text="{Binding PoiCount, StringFormat='{0} địa điểm'}" 
                                           TextColor="{AppThemeBinding Light=#34495E, Dark=#BDC3C7}"
                                           FontSize="14" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="8">
                                <Frame BackgroundColor="{AppThemeBinding Light=#E8F8F5, Dark=#102A26}"
                                       CornerRadius="12"
                                       Padding="12,6"
                                       HasShadow="False"
                                       BorderColor="Transparent">
                                    <Label Text="{Binding DownloadStatus}" 
                                           TextColor="#16A085"
                                           FontSize="11"
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Center"/>
                                </Frame>
                                
                                <Label Text="{Binding Price, StringFormat='-{0:N0} xu'}" 
                                       TextColor="#E74C3C" 
                                       FontSize="12" 
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"/>

                                <Label Text="Đã thanh toán" 
                                       TextColor="#27AE60" 
                                       FontSize="10" 
                                       HorizontalTextAlignment="Center"
                                       FontAttributes="Italic"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
