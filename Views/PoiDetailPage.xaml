<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp1.Views.PoiDetailPage"
    Title="POI Detail"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{Binding Poi.Name}" FontSize="20" FontAttributes="Bold" />
            <Label Text="{Binding Poi.Summary}" FontSize="14" />
            <Label Text="{Binding Poi.NarrationShort}" FontSize="14" TextColor="{StaticResource TextSecondary}" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="🔊 Play" Clicked="OnPlayClicked" />
                <Button Text="⏹ Stop" Clicked="OnStopClicked" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
