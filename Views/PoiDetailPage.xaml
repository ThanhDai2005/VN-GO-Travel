<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp1.Views.PoiDetailPage"
    Title="POI Detail"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Label Text="{Binding Poi.Localization.Name}" FontSize="20" FontAttributes="Bold" />
            <Label Text="{Binding Poi.Localization.Summary}" FontSize="14" />
            <Label Text="{Binding Poi.Localization.NarrationShort}" FontSize="14" TextColor="{StaticResource TextSecondary}" />

            <Label Text="Auto translated"
                   FontSize="11"
                   FontAttributes="Italic"
                   TextColor="{StaticResource TextSecondary}"
                   IsVisible="{Binding Poi.IsAutoTranslated}" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="🗺 Open on Map" Clicked="OnOpenOnMapClicked" />
                <Button Text="🔊 Play" Clicked="OnPlayClicked" />
                <Button Text="⏹ Stop" Clicked="OnStopClicked" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
