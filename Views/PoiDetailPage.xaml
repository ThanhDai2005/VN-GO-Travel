<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp1.Views.PoiDetailPage"
    Title="POI Detail"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Frame
                BackgroundColor="{StaticResource SurfaceCard}"
                BorderColor="{StaticResource BorderLight}"
                Padding="16"
                CornerRadius="24"
                HasShadow="False">

                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="{Binding Poi.Name}"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}"
                        LineBreakMode="WordWrap" />

                    <Label
                        Text="{Binding Poi.Summary}"
                        FontSize="14"
                        TextColor="{StaticResource TextSecondary}"
                        LineBreakMode="WordWrap" />

                    <Label
                        Text="{Binding Poi.NarrationLong}"
                        FontSize="14"
                        TextColor="{StaticResource TextSecondary}"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="10">

                <Button
                    Text="{Binding OpenOnMapButtonText}"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnOpenOnMapClicked"
                    Grid.Row="0"
                    Grid.Column="0" />

                <Button
                    Text="{Binding PlayButtonText}"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="OnPlayClicked"
                    Grid.Row="0"
                    Grid.Column="1" />

                <Button
                    Text="{Binding StopButtonText}"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnStopClicked"
                    Grid.Row="1"
                    Grid.ColumnSpan="2" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
