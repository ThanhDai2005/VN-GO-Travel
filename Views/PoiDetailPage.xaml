<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiApp1.Views"
    x:Class="MauiApp1.Views.PoiDetailPage"
    Title="Chi tiết địa danh"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <Grid RowDefinitions="*">
        <!-- BACKGROUND DECORATION -->
        <BoxView VerticalOptions="Start" HeightRequest="220">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource BrandPrimary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BrandPrimaryDark}" Offset="0.8" />
                    <GradientStop Color="{StaticResource SurfaceBackground}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView>
            <VerticalStackLayout Padding="20,40,20,40" Spacing="0">
                
                <!-- PROGRESS LOADING -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                   IsVisible="{Binding IsBusy}" 
                                   Color="White"
                                   Margin="0,0,0,20"/>

                <!-- HEADER LABEL -->
                <Label Text="{Binding Poi.Localization.Name}" 
                       Style="{StaticResource PageTitleLabel}"
                       TextColor="White"
                       HorizontalOptions="Start"
                       Margin="4,0,0,24" />

                <!-- MAIN CARD -->
                <Border Style="{StaticResource CardBorder}" Padding="24">
                    <VerticalStackLayout Spacing="20">
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Giới thiệu" 
                                   Style="{StaticResource SectionTitle}" 
                                   FontSize="18" />
                            
                            <Label Text="{Binding Poi.Localization.Summary}" 
                                   Style="{StaticResource BodyText}" 
                                   FontSize="16"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Thông tin chi tiết" 
                                   Style="{StaticResource SectionTitle}" 
                                   FontSize="14" 
                                   TextColor="{StaticResource TextSecondary}" />
                            
                            <Label Text="{Binding Poi.Localization.NarrationShort}" 
                                   Style="{StaticResource BodyText}" />
                        </VerticalStackLayout>

                        <!-- HYBRID TRANSLATION BADGES -->
                        <HorizontalStackLayout Spacing="8">
                            <!-- AUTO TRANSLATED BADGE -->
                            <Border IsVisible="{Binding Poi.ShowBadgeAutoTranslated}"
                                    BackgroundColor="{StaticResource BrandAccent}"
                                    StrokeThickness="0"
                                    HorizontalOptions="Start"
                                    Padding="8,4"
                                    StrokeShape="RoundRectangle 8">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="✨" FontSize="12" VerticalOptions="Center" />
                                    <Label Text="Bản dịch tự động"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandDark}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- OUTDATED CONTENT BADGE -->
                            <Border IsVisible="{Binding Poi.ShowBadgeOutdated}"
                                    BackgroundColor="#FFF3CD"
                                    StrokeThickness="1"
                                    Stroke="#FFEEBA"
                                    HorizontalOptions="Start"
                                    Padding="8,4"
                                    StrokeShape="RoundRectangle 8">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="⚠️" FontSize="12" VerticalOptions="Center" />
                                    <Label Text="Nội dung cũ"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#856404"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </HorizontalStackLayout>

                        <!-- ZONE PURCHASE BANNER -->
                        <Border IsVisible="{Binding ShowPurchaseBanner}"
                                BackgroundColor="{StaticResource SurfaceSoft}"
                                StrokeThickness="0"
                                Padding="16,12"
                                Margin="0,0,0,8"
                                StrokeShape="RoundRectangle 12">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="🏷️" FontSize="20" VerticalOptions="Center" />
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding PurchaseBannerTitle}" 
                                           TextColor="{StaticResource BrandPrimary}" 
                                           FontAttributes="Bold" 
                                           FontSize="14"/>
                                    <Label Text="{Binding PurchaseBannerDescription}" 
                                           TextColor="{StaticResource TextSecondary}" 
                                           FontSize="12"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PurchaseZoneCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderLight}" Margin="0,4" />

                        <!-- BUTTON ACTIONS -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                            
                            <!-- Standard Play (Free) -->
                            <Button Text="🔊 Nghe tóm tắt" 
                                    Style="{StaticResource PrimaryButton}"
                                    Clicked="OnPlayClicked"
                                    Grid.Column="0"
                                    IsVisible="{Binding ShowSummaryButton}" />

                            <Button Text="⏹ Dừng" 
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnStopClicked"
                                    Grid.Column="1" />

                            <!-- DETAILED NARRATION BUTTON -->
                            <Button Text="{Binding DetailedActionButtonText}"
                                    Style="{StaticResource CTAButton}"
                                    Clicked="OnPlayDetailedClicked"
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    IsVisible="{Binding ShowDetailedCTA}" />

                            <views:AudioPlayerComponent Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        IsVisible="{Binding ShowPurchasedAudioPlayer}" />

                            <Button Text="🗺 Xem trên bản đồ" 
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnOpenOnMapClicked"
                                    Grid.Row="2"
                                    Grid.ColumnSpan="2" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
