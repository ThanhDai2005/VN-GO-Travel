<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="MauiApp1.Views.MapPage">

    <Grid>
        <maps:Map
            x:Name="Map"
            IsShowingUser="True"
            MapType="Street" />

        <Border IsVisible="{Binding IsPoiPanelVisible}"
                VerticalOptions="End"
                Margin="20, 0, 20, 30"
                Padding="20"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 20">

            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Offset="0,5" Radius="10" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding SelectedPoi.Name}" 
                       FontAttributes="Bold" 
                       FontSize="20" 
                       TextColor="Black"/>

                <Label Text="{Binding SelectedPoi.NarrationShort}" 
                       FontSize="15" 
                       TextColor="DarkGray"
                       MaxLines="3"
                       LineBreakMode="TailTruncation"/>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0, 10, 0, 0">
                    <Button Grid.Column="0" 
                            Text="Nghe chi tiết" 
                            Clicked="OnListenDetailedClicked" 
                            BackgroundColor="#2196F3" 
                            TextColor="White" 
                            CornerRadius="10"
                            FontAttributes="Bold"/>

                    <Button Grid.Column="1" 
                            Text="Đóng" 
                            Clicked="OnClosePanelClicked" 
                            BackgroundColor="#EEEEEE" 
                            TextColor="Black" 
                            CornerRadius="10"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>