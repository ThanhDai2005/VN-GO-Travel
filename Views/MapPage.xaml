<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="MauiApp1.Views.MapPage"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <!-- FIX: chia layout đúng -->
    <Grid RowDefinitions="*,Auto">

        <!-- MAP -->
        <maps:Map x:Name="Map"
                  Grid.Row="0"
                  IsShowingUser="True"
                  MapType="Street" 
                  MapClicked="OnMapClicked" />

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Margin="16,48,16,0"
                Padding="12"
                BackgroundColor="#FDFBF9EE"
                Stroke="{StaticResource BorderLight}"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="Start">

            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

                <Border BackgroundColor="#F8E9E0"
                        Padding="10"
                        StrokeShape="RoundRectangle 16">
                    <Label Text="🧭" FontSize="18" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="{Binding MapTitle}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandPrimaryDark}" />
                    <Label Text="{Binding MapSubtitle}"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <!-- Compact 2x2 language selector (keeps header height stable) -->
                <Grid Grid.Column="2"
                      ColumnDefinitions="Auto,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="6"
                      RowSpacing="6">
                    <Button x:Name="VietnameseButton"
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="VN"
                            Clicked="OnVietnameseClicked"
                            WidthRequest="46"
                            HeightRequest="40"
                            CornerRadius="14" />

                    <Button x:Name="EnglishButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="EN"
                            Clicked="OnEnglishClicked"
                            WidthRequest="46"
                            HeightRequest="40"
                            CornerRadius="14" />

                    <Button x:Name="ChineseButton"
                            Grid.Row="1"
                            Grid.Column="0"
                            Text="中文"
                            Clicked="OnChineseClicked"
                            WidthRequest="46"
                            HeightRequest="40"
                            CornerRadius="14" />

                    <Button x:Name="JapaneseButton"
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="日本語"
                            Clicked="OnJapaneseClicked"
                            WidthRequest="46"
                            HeightRequest="40"
                            CornerRadius="14" />
                </Grid>

                <!-- QR button removed: QR tab added to Shell -->
            </Grid>
        </Border>

        <!-- BOTTOM PANEL -->
        <Border x:Name="BottomPanel"
        Grid.Row="1"
        HeightRequest="220"
        Margin="16,0,16,20"
        BackgroundColor="White"
        Stroke="{StaticResource BorderLight}"
        StrokeShape="RoundRectangle 28"
        IsVisible="False"
        Opacity="0">

            <Border.Shadow>
                <Shadow Brush="{StaticResource ShadowColor}"
                Opacity="0.18"
                Offset="0,8"
                Radius="18" />
            </Border.Shadow>

            <!-- ✅ FIX: thêm ScrollView -->
            <ScrollView>

                <Grid RowDefinitions="Auto,Auto,Auto">

                    <!-- drag indicator -->
                    <BoxView HeightRequest="4"
                     WidthRequest="42"
                     HorizontalOptions="Center"
                     Margin="0,10"
                     BackgroundColor="#D8C8C0"
                     CornerRadius="2" />

                    <!-- CONTENT -->
                    <VerticalStackLayout Grid.Row="1"
                                 Padding="20,8"
                                 Spacing="8">

                        <Label Text="{Binding SelectedPoi.Name}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                        <Label Text="{Binding SelectedPoi.NarrationShort}"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                <!-- BUTTONS -->
                    <Grid Grid.Row="2"
                  Padding="16"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="10">

                        <Button Text="{Binding ListenDetailedButtonText}"
                                Style="{StaticResource PrimaryButton}"
                                Clicked="OnListenDetailedClicked" />

                        <Button Grid.Column="1"
                                Text="{Binding StopButtonText}"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnStopAudioClicked" />
                    </Grid>

                </Grid>

            </ScrollView>
        </Border>

    </Grid>
</ContentPage>