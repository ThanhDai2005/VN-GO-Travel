<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="MauiApp1.Views.MapPage"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <!-- FIX: chia layout đúng -->
    <Grid RowDefinitions="*,Auto">

        <!-- MAP -->
        <maps:Map x:Name="Map"
                  Grid.Row="0"
                  IsShowingUser="True"
                  MapType="Street" 
                  MapClicked="OnMapClicked" />

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Margin="16,48,16,0"
                Padding="12"
                BackgroundColor="#FDFBF9EE"
                Stroke="{StaticResource BorderLight}"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="Start">

            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">

                <Border BackgroundColor="#F8E9E0"
                        Padding="10"
                        StrokeShape="RoundRectangle 16">
                    <Label Text="🧭" FontSize="18" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Bản đồ Việt Nam"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandPrimaryDark}" />
                    <Label Text="Khám phá bằng vị trí và âm thanh"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="2"
                                   IsRunning="{Binding IsTranslating}"
                                   IsVisible="{Binding IsTranslating}"
                                   VerticalOptions="Center"
                                   WidthRequest="28"
                                   HeightRequest="28" />

                <!-- Language selector button — opens LanguageSelectorPage modal -->
                <Button Grid.Column="3"
                        Text="{Binding CurrentLanguageLabel}"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="13"
                        HeightRequest="40"
                        WidthRequest="150"
                        VerticalOptions="Center"
                        Clicked="OnLanguageButtonClicked" />

                <!-- QR button removed: QR tab added to Shell -->
            </Grid>
        </Border>

        <!-- BOTTOM PANEL -->
        <Border x:Name="BottomPanel"
        Grid.Row="1"
        HeightRequest="220"
        Margin="16,0,16,20"
        BackgroundColor="White"
        Stroke="{StaticResource BorderLight}"
        StrokeShape="RoundRectangle 28"
        IsVisible="False"
        Opacity="0">

            <Border.Shadow>
                <Shadow Brush="{StaticResource ShadowColor}"
                Opacity="0.18"
                Offset="0,8"
                Radius="18" />
            </Border.Shadow>

            <!-- ✅ FIX: thêm ScrollView -->
            <ScrollView>

                <Grid RowDefinitions="Auto,Auto,Auto">

                    <!-- drag indicator -->
                    <BoxView HeightRequest="4"
                     WidthRequest="42"
                     HorizontalOptions="Center"
                     Margin="0,10"
                     BackgroundColor="#D8C8C0"
                     CornerRadius="2" />

                    <!-- CONTENT -->
                    <VerticalStackLayout Grid.Row="1"
                                 Padding="20,8"
                                 Spacing="8">

                        <Label Text="{Binding SelectedPoi.Localization.Name}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                        <Label Text="{Binding SelectedPoi.Localization.NarrationShort}"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />

                        <Label Text="Auto translated"
                               FontSize="11"
                               FontAttributes="Italic"
                               TextColor="{StaticResource TextSecondary}"
                               IsVisible="{Binding SelectedPoi.IsAutoTranslated}" />
                    </VerticalStackLayout>

                <!-- BUTTONS -->
                    <Grid Grid.Row="2"
                  Padding="16"
                  RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  RowSpacing="10">

                        <Button Text="🔊 Nghe chi tiết"
                                Style="{StaticResource PrimaryButton}"
                                Clicked="OnListenDetailedClicked" />

                        <Button Grid.Column="1"
                        Text="⏹ Dừng"
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnStopAudioClicked" />

                        <Button Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Text="📄 Xem chi tiết địa điểm"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnOpenDetailClicked" />
                    </Grid>

                </Grid>

            </ScrollView>
        </Border>

    </Grid>
</ContentPage>